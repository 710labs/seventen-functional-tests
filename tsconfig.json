{
	"compilerOptions": {
		"target": "ESNext",
		"module": "commonjs",
		"moduleResolution": "node",
		"strict": false,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"noEmit": true,
		"types": ["node"]
	},
	"include": ["**/*.ts"],
	"exclude": ["node_modules", "output", "playwright-report", "test-results"]
}
